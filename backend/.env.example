LLM_PROVIDER=gemini

# Multiple Gemini keys for automatic rotation on 429s
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_2=your_gemini_api_key_here
GEMINI_API_KEY_3=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Batch tuning (free-tier friendly)
BATCH_MAX_CONCURRENCY=2
BATCH_REQUEST_DELAY_SECONDS=1.5
BATCH_MAX_RETRIES_PER_MESSAGE=3